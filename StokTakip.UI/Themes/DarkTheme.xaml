<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════ KOYU TEMA ═══════ -->

    <!-- Yüzeyler -->
    <SolidColorBrush x:Key="BgBrush"            Color="#15191F"/>
    <SolidColorBrush x:Key="SurfaceBrush"       Color="#212832"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"    Color="#262E39"/>
    <SolidColorBrush x:Key="HeaderBgBrush"      Color="#0E1217"/>

    <!-- Metin -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#E7EBF1"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="#9BA7B4"/>
    <SolidColorBrush x:Key="PrimaryBrush"       Color="#82B1E8"/>
    <SolidColorBrush x:Key="HeaderTextBrush"    Color="#F1F5F9"/>
    <SolidColorBrush x:Key="HeaderSubTextBrush" Color="#89A5C2"/>

    <!-- Vurgu -->
    <SolidColorBrush x:Key="AccentBrush"        Color="#3E80C1"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="#5399D8"/>
    <SolidColorBrush x:Key="DangerBrush"        Color="#E85D4E"/>
    <SolidColorBrush x:Key="SuccessBrush"       Color="#33CE77"/>
    <SolidColorBrush x:Key="WarningBrush"       Color="#E89B45"/>

    <!-- Rozet / panel arka planları -->
    <SolidColorBrush x:Key="SuccessBgBrush"     Color="#1D3327"/>
    <SolidColorBrush x:Key="DangerBgBrush"      Color="#38231F"/>
    <SolidColorBrush x:Key="WarningBgBrush"     Color="#392E1B"/>
    <SolidColorBrush x:Key="DangerBorderBrush"  Color="#5C302B"/>

    <!-- Diğer -->
    <SolidColorBrush x:Key="BorderBrush"        Color="#363F4B"/>
    <SolidColorBrush x:Key="LightBlueBrush"     Color="#253340"/>
    <SolidColorBrush x:Key="RowHoverBrush"      Color="#2C3A49"/>

</ResourceDictionary>
