<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════ AÇIK TEMA ═══════ -->

    <!-- Yüzeyler -->
    <SolidColorBrush x:Key="BgBrush"            Color="#F4F6F9"/>
    <SolidColorBrush x:Key="SurfaceBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"    Color="#FAFCFF"/>
    <SolidColorBrush x:Key="HeaderBgBrush"      Color="#1A3A5C"/>

    <!-- Metin -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1A2536"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="#6B7A8D"/>
    <SolidColorBrush x:Key="PrimaryBrush"       Color="#1A3A5C"/>
    <SolidColorBrush x:Key="HeaderTextBrush"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderSubTextBrush" Color="#9CBCD8"/>

    <!-- Vurgu -->
    <SolidColorBrush x:Key="AccentBrush"        Color="#2E6DA4"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="#1A3A5C"/>
    <SolidColorBrush x:Key="DangerBrush"        Color="#C0392B"/>
    <SolidColorBrush x:Key="SuccessBrush"       Color="#27AE60"/>
    <SolidColorBrush x:Key="WarningBrush"       Color="#E67E22"/>

    <!-- Rozet / panel arka planları -->
    <SolidColorBrush x:Key="SuccessBgBrush"     Color="#E8F5E9"/>
    <SolidColorBrush x:Key="DangerBgBrush"      Color="#FFEBEE"/>
    <SolidColorBrush x:Key="WarningBgBrush"     Color="#FFF3E0"/>
    <SolidColorBrush x:Key="DangerBorderBrush"  Color="#FFCDD2"/>

    <!-- Diğer -->
    <SolidColorBrush x:Key="BorderBrush"        Color="#D5DBE1"/>
    <SolidColorBrush x:Key="LightBlueBrush"     Color="#EBF3FB"/>
    <SolidColorBrush x:Key="RowHoverBrush"      Color="#EBF3FB"/>

</ResourceDictionary>
