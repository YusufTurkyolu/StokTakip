<Application x:Class="StokTakip.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- [0] Tema sözlüğü — ThemeManager çalışma anında bunu değiştirir.
                     Sıralama önemli: tema her zaman ilk sözlük olmalı. -->
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
                <!-- [1] Kontrol stilleri (renkleri temadan DynamicResource ile alır) -->
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
