<Window x:Class="StokTakip.UI.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yazdırma Önizleme — Malzeme Alım Formu"
        Width="820" Height="920"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Üst çubuk: bilgi + yazdır -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="14,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button Content="🖨  Yazdır" Style="{StaticResource BtnPrimary}"
                            Click="BtnPrint_Click" Margin="0,0,8,0"/>
                    <Button Content="Kapat" Style="{StaticResource BtnGhost}"
                            Click="BtnClose_Click"/>
                </StackPanel>
                <TextBlock x:Name="TxtInfo" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Sayfa önizlemesi (alt barında yakınlaştırma kontrolleri hazır gelir) -->
        <FlowDocumentPageViewer x:Name="Viewer" Grid.Row="1" Zoom="90"/>
    </Grid>
</Window>
