<Window x:Class="StokTakip.UI.Views.EditTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="İşlem Düzenle"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource BgBrush}">

    <StackPanel Margin="28">
        <TextBlock Text="İşlem Miktarını Düzenle" FontSize="17" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock x:Name="TxtItemName" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Yeni Miktar" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtQuantity" Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,6" KeyDown="TxtQuantity_KeyDown"/>
        <TextBlock x:Name="TxtCurrent" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                   Margin="0,0,0,18"/>

        <TextBlock x:Name="TxtError" Foreground="{DynamicResource DangerBrush}" FontSize="12"
                   Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Style="{StaticResource BtnGhost}"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Kaydet"
                    Style="{StaticResource BtnPrimary}" Click="BtnSave_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
