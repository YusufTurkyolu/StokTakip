<Window x:Class="StokTakip.UI.Views.AddItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yeni Ürün Ekle"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource BgBrush}">

    <StackPanel Margin="28">
        <TextBlock Text="📦 Yeni Ürün Ekle" FontSize="17" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,20"/>

        <TextBlock Text="Ürün Adı" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtItemName" Style="{StaticResource ModernTextBox}"
                 MaxLength="200" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Başlangıç Stok" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtInitialStock" Style="{StaticResource ModernTextBox}" Text="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Minimum Eşik" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtMinThreshold" Style="{StaticResource ModernTextBox}" Text="5"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="TxtError" Foreground="{DynamicResource DangerBrush}" FontSize="12"
                   Margin="0,0,0,10" TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Style="{StaticResource BtnGhost}"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Ekle" Style="{StaticResource BtnSuccess}"
                    Click="BtnAdd_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
