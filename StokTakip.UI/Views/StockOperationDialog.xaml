<Window x:Class="StokTakip.UI.Views.StockOperationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stok İşlemi"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource BgBrush}">

    <StackPanel Margin="28">
        <TextBlock x:Name="TxtTitle" FontSize="17" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock x:Name="TxtItemName" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                   Margin="0,0,0,20"/>

        <!-- Departman — yalnızca stok ÇIKIŞINDA görünür.
             Girişler genel bütçeden yapıldığı için birim sorulmaz. -->
        <TextBlock x:Name="LblDepartment" Text="Departman" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <ComboBox x:Name="CmbDepartment"
                  Style="{StaticResource ModernCombo}"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  Margin="0,0,0,14"/>

        <!-- Miktar -->
        <TextBlock Text="Miktar" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtQuantity" Style="{StaticResource ModernTextBox}"
                 Text="1" Margin="0,0,0,6"/>
        <TextBlock x:Name="TxtStockInfo" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                   Margin="0,0,0,18"/>

        <TextBlock x:Name="TxtError" Foreground="{DynamicResource DangerBrush}" FontSize="12"
                   Margin="0,0,0,10" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Style="{StaticResource BtnGhost}"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnConfirm" Content="Kaydet"
                    Style="{StaticResource BtnPrimary}" Click="BtnConfirm_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
