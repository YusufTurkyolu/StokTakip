<Window x:Class="StokTakip.UI.Views.AddDepartmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Departman Ekle"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource BgBrush}">

    <StackPanel Margin="28">
        <TextBlock Text="🏢 Yeni Departman" FontSize="17" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,6"/>
        <TextBlock Text="Eklenen departman, stok çıkışı ve rapor listelerinde görünür."
                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,18"/>

        <TextBlock Text="Departman Adı" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtName" Style="{StaticResource ModernTextBox}"
                 MaxLength="150" Margin="0,0,0,14" KeyDown="TxtName_KeyDown"/>

        <TextBlock x:Name="TxtError" Foreground="{DynamicResource DangerBrush}" FontSize="12"
                   Margin="0,0,0,10" TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Style="{StaticResource BtnGhost}"
                    Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Ekle" Style="{StaticResource BtnSuccess}"
                    Click="BtnAdd_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
